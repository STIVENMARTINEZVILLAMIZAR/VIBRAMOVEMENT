{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "public/*": ["src/public/*"],
      "backend/*": ["src/backend/*"],
      "backend/*.web.js": ["src/backend/*.web.js"]
    },
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.json"
  ],
  "exclude": [
    "node_modules"
  ],
  "typeAcquisition": {
    "enable": true
  }
}
